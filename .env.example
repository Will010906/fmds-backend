# === Backend (Express) — variables de entorno ===
# Copia este archivo como .env y rellena con tus valores reales.
# En producción (Railway) estas variables se configuran en el panel del servicio.

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=fmds

# Autenticación (cadena secreta larga y aleatoria para firmar los JWT)
JWT_SECRET=cambia_esto_por_una_cadena_secreta_larga

# Openpay — se obtienen en https://dashboard.openpay.mx (Configuración > Llaves)
OPENPAY_MERCHANT_ID=tu_merchant_id
OPENPAY_PRIVATE_KEY=sk_tu_llave_privada

# URL de la API de Openpay:
#   https://sandbox-api.openpay.mx  = ambiente de pruebas (por defecto)
#   https://api.openpay.mx          = cobros reales (producción)
OPENPAY_BASE_URL=https://sandbox-api.openpay.mx
